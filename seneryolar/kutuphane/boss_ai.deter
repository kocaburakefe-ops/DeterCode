YETENEK boss_karar_ver oyuncu_can
    EGER oyuncu_can < 50
        yazdir "BOSS: 'Zayıfladın, sonunu getiriyorum!'"
        yetenek_cagir saldir "Oyuncu" 30
    BITIR_EGER

    EGER oyuncu_can > 80
        yazdir "BOSS: 'Hala çok enerjisin, seni yormam lazım!'"
        yetenek_cagir geri_cekil
    BITIR_EGER
YETENEK_BITIR
  
