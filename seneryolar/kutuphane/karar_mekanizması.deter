// Karar Mekanizması Kütüphanesi
YETENEK can_kontrol miktar
    EGER miktar < 30
        yazdir "UYARI: Can kritik! İyileşme tetikleniyor..."
        yetenek_cagir iyiles 50
    BITIR_EGER
YETENEK_BITIR

YETENEK dusman_durum_kontrol can_degeri
    EGER can_degeri < 20
        yazdir "DÜŞMAN ZAYIFLADI: Bitirici darbe zamanı!"
    BITIR_EGER
YETENEK_BITIR

