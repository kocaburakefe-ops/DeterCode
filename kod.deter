# DeterCode Döngü ve Krank Mili Testi
SET tur = 1

# Döngü Başlıyor: Tur sayısı 5'ten küçük olduğu sürece dön!
LOOP tur < 5
LOG E36 pistte gazliyor! Su anki tur:
LOG tur

# Her tur bittiğinde tur sayısını 1 artırıyoruz (Pistonu itiyoruz)
CALC tur = tur + 1
ENDLOOP

# Döngü kırıldıktan sonra akış buradan devam etmeli
LOG Döngü basariyla bitti, araba pit alanina girdi.
LOG Son durum tur sayisi:
LOG tur
