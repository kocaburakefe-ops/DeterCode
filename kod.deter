# DeterCode IF-ELSE Beyin Testi
SET e36_beygir = 180

# Test: 180 beygir 200'den büyük mü? (Yanlış! O yüzden ELSE bloğu çalışmalı)
IF e36_beygir > 200
LOG Bu araba asfalta sigmaz! (IF BLOGU)
ELSE
LOG 180 beygir az kanka, bu arabaya acil yazilim atiyoruz! (ELSE BLOGU)
SET e36_beygir = 250
ENDIF

# Bakalım ELSE bloğunun içindeki SET komutu çalışmış mı?
LOG Güncel motor gücü kontrol ediliyor...
LOG e36_beygir
