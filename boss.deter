ekrani_temizle

boss_can = 30
yazdir "Zindanın Gardiyanı ejderha uyandı!"

// boss_can 0'dan büyük olduğu SÜRECE bu döngü çalışacak:
KENKEN boss_can > 0
hasar_ver boss_can 10

